{
	"name": "mattriz",
	"version": "1.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "node scripts/warn-development-env.mjs && vite --host 127.0.0.1",
		"build": "tsc && vite build && node scripts/validate-hreflang.mjs",
		"test": "vitest run",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "npm run lint && npm run format:check && npm test && node scripts/check-build.mjs"
	},
	"dependencies": {
		"three": "0.185.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/three": "0.185.0",
		"eslint": "10.6.0",
		"eslint-config-prettier": "10.1.8",
		"globals": "17.7.0",
		"prettier": "3.8.5",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.0",
		"vite": "8.1.0",
		"vitest": "4.1.9"
	}
}
